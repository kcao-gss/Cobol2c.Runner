{
  "Runner": {
    "UseMocks": false,
    // VM paths (relative to exe; set Runner__JobsPath / Runner__OutputPath env vars to override for dev)
    "FixturesPath": "../../fixtures",   // MockTaExecutor only — unused when UseMocks=false
    "JobsPath": "jobs",                 // VM: <exe dir>\jobs\  |  Dev: set Runner__JobsPath=../../fixtures/jobs
    "OutputPath": "out",                // VM: <exe dir>\out\   |  Dev: set Runner__OutputPath=../../out
    "ScriptsPath": "scripts",
    "PollIntervalMs": 2000,

    // Production-only — ignored when UseMocks=true:
    "AutoRecover": true,          // reboot + re-login + retry affected TCs on VM wedge (cap: 2 per suite)
    "RebootBeforeRun": true,      // reboot VM before each batch; clean boot eliminates stale-session false positives (~5-10 min/job)
    "MachinePool": ["TGFTA-118", "TGFTA-119", "TGFTA-120", "TGFTA-124", "TGFTA-125", "TGFTA-126"],
    "ConfirmationRuns": 3,        // number of machines per job; TC regressed only if it fails on ALL machines (unanimous)
    "JobTimeoutMinutes": 180,     // 3h covers two 45-min suites × up to 2 recoveries each (reboot ~10 min each)
    "DashboardApiUrl": null,
    "JobClientId": null,
    "JobClientSecret": null
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
